From ac56bc4fe97ec403cb655379e70318beecc6d2d8 Mon Sep 17 00:00:00 2001
From: Yan Markman <ymarkman@marvell.com>
Date: Mon, 30 Mar 2026 18:04:42 +0300
Subject: [PATCH 1/1] Kconfig KEMPLD_DISABLE_ALL disable MFD-children
 autoinstall

bool "Disable all KEMPLD children at runtime"
default n

If set, no KEMPLD child devices will be auto-instantiated.
Modules will still be built (CONFIG_*_KEMPLD=m) and present on
filesystem, but nothing will be auto-loaded.

Signed-off-by: Yan Markman <ymarkman@marvell.com>
---
 drivers/gpio/Kconfig      |  8 ++++++++
 drivers/mfd/kempld-core.c | 10 ++++++++++
 2 files changed, 18 insertions(+)

diff --git a/drivers/gpio/Kconfig b/drivers/gpio/Kconfig
index d93cd4f72..ba8aa5f19 100644
--- a/drivers/gpio/Kconfig
+++ b/drivers/gpio/Kconfig
@@ -1387,6 +1387,14 @@ config GPIO_KEMPLD
 	  This driver can also be built as a module. If so, the module will be
 	  called gpio-kempld.
 
+config KEMPLD_DISABLE_ALL
+	bool "Disable all KEMPLD children at runtime"
+	default n
+	help
+	  If set, no KEMPLD child devices will be auto-instantiated.
+	  Modules will still be built (CONFIG_*_KEMPLD=m) and present on filesystem,
+	  but nothing will be auto-loaded.
+
 config GPIO_LJCA
 	tristate "INTEL La Jolla Cove Adapter GPIO support"
 	depends on USB_LJCA
diff --git a/drivers/mfd/kempld-core.c b/drivers/mfd/kempld-core.c
index 8a332852b..a054df516 100644
--- a/drivers/mfd/kempld-core.c
+++ b/drivers/mfd/kempld-core.c
@@ -24,6 +24,13 @@ module_param_string(force_device_id, force_device_id,
 		    sizeof(force_device_id), 0);
 MODULE_PARM_DESC(force_device_id, "Override detected product");
 
+static bool allow_create = false;
+module_param(allow_create, bool, 0644);
+MODULE_PARM_DESC(allow_create,
+    "Control KEMPLD child device creation:\n"
+    "  false = skip creation (default)\n"
+    "  true  = create child devices when module loads");
+
 /*
  * Get hardware mutex to block firmware from accessing the pld.
  * It is possible for the firmware may hold the mutex for an extended length of
@@ -97,6 +104,9 @@ static int kempld_register_cells_generic(struct kempld_device_data *pld)
 	struct mfd_cell devs[KEMPLD_MAX_DEVS] = {};
 	int i = 0;
 
+	if (IS_ENABLED(CONFIG_KEMPLD_DISABLE_ALL) && !allow_create)
+		pld->feature_mask = 0;
+
 	if (pld->feature_mask & KEMPLD_FEATURE_BIT_I2C)
 		devs[i++].name = kempld_dev_names[KEMPLD_I2C];
 
-- 
