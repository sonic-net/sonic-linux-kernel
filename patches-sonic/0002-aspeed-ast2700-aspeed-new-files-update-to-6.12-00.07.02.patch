+static int clz16(u16 x)
+{
+	int n = 0;
+
+	if (x == 0)
+		return 16;
+
+	if (x <= 0x00ff) {
+		n += 8;
+		x <<= 8;
+	}
+	if (x <= 0x0fff) {
+		n += 4;
+		x <<= 4;
+	}
+	if (x <= 0x3fff) {
+		n += 2;
+		x <<= 2;
+	}
+	if (x <= 0x7fff)
+		n += 1;
+
+	return n;
+}
+
+static u16 find_max_speed(u16 cap)
+{
+	return 15 - clz16(cap & ~LTPI_SP_CAP_DDR);
+}
